# Database Configuration
DB_HOST=localhost
DB_DATABASE=attendance-system
DB_USERNAME=root
DB_PASSWORD=

# Application Settings
APP_NAME="JAJR Attendance System"
APP_URL=http://localhost/jajr-v2
APP_ENV=development
APP_DEBUG=true

# Session Configuration
SESSION_NAME=jajr_session
SESSION_LIFETIME=120

# QR Scanner Settings
QR_SCAN_COOLDOWN=3000
QR_OFFLINE_MODE=true

# Security
ALLOWED_ORIGINS=http://localhost
CSRF_PROTECTION=true
